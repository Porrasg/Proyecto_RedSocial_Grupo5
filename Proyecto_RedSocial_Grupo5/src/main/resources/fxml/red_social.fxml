<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.ui.RedSocialController">

    <top>
        <HBox spacing="10" style="-fx-padding: 10;">
            <Button text="Volver al menú" onAction="#onVolverMenu"/>
        </HBox>
    </top>

    <center>
        <AnchorPane fx:id="graphPane" prefWidth="900" prefHeight="600"/>
    </center>

    <bottom>
        <Label text="Click izquierdo: crear amistad | Click derecho: eliminar amistad"
               style="-fx-padding: 10; -fx-font-weight: bold;"/>
    </bottom>
</BorderPane>