<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.ui.RedSocialController">

    <!-- Barra superior -->
    <top>
        <HBox spacing="10" style="-fx-padding: 10;">
            <Button text="Volver al menú" onAction="#onVolverMenu"/>
        </HBox>
    </top>

    <!-- Área del grafo con scroll -->
    <center>
        <ScrollPane fx:id="scrollPane"
                    fitToWidth="true"
                    fitToHeight="true"
                    pannable="true">

            <content>
                <AnchorPane fx:id="graphPane" prefWidth="1200" prefHeight="800"/>
            </content>

        </ScrollPane>
    </center>

    <!-- Instrucciones -->
    <bottom>
        <Label text="Click izquierdo: crear amistad | Click derecho: eliminar amistad"
               style="-fx-padding: 10; -fx-font-weight: bold;"/>
    </bottom>

</BorderPane>