<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<!--
    Vista para agregar un nuevo grupo.
    Permite ingresar nombre, seleccionar color y guardar el grupo.
-->

<VBox spacing="15" alignment="CENTER"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.ui.AddGroupController">

    <!-- Espaciado interno -->
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Título -->
    <Label text="Agregar Grupo"
           style="-fx-font-size:18px; -fx-font-weight:bold;" />

    <!-- Campo de nombre -->
    <TextField fx:id="txtNombreGrupo"
               promptText="Nombre del grupo"
               maxWidth="250"/>

    <!-- Selector de color -->
    <ColorPicker fx:id="cpColor"
                 maxWidth="250"/>

    <!-- Botón guardar -->
    <Button text="Guardar Grupo"
            onAction="#onGuardarGrupo"/>

    <!-- Botón volver -->
    <Button text="Volver"
            onAction="#onVolver"/>

    <!--
        Label que uso para mostrar mensajes al usuario
        (por ejemplo confirmación o errores).
    -->
    <Label fx:id="lblStatus"/>

</VBox>