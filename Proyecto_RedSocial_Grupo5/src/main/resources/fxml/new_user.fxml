<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<!--
    Vista para crear un nuevo usuario.
    Incluye datos personales, contraseña y selección de avatar.
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.ui.NewUserController"
      spacing="12">

    <!-- Espaciado interno -->
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <!-- Título -->
    <Label text="Nuevo Usuario" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <!-- Formulario -->
    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="35"/>
            <ColumnConstraints percentWidth="65"/>
        </columnConstraints>

        <Label text="Usuario:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtUsername" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Contraseña:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <PasswordField fx:id="txtPassword" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Primer nombre:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtPrimerNombre" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Primer apellido:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtPrimerApellido" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Segundo apellido:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="txtSegundoApellido" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Fecha nacimiento:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dpFechaNacimiento" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Avatar:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cbAvatar" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

        <!-- Vista previa -->
        <Label text="Vista previa:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
        <ImageView fx:id="imgAvatarPreview"
                   fitWidth="80"
                   fitHeight="80"
                   preserveRatio="true"
                   GridPane.rowIndex="7"
                   GridPane.columnIndex="1"/>
    </GridPane>

    <!-- Botones -->
    <HBox spacing="10">
        <Button text="Guardar" onAction="#onGuardar"/>
        <Button text="Limpiar" onAction="#onLimpiar"/>
        <Button text="Volver" onAction="#onVolver"/>
    </HBox>

    <!-- Mensajes -->
    <Label fx:id="lblStatus" />
</VBox>